{
  "name": "code-intelligence-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal MCP server for code intelligence",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --exclude node_modules --exclude dist src/index.ts",
